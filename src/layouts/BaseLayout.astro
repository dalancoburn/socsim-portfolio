---
import '../styles/global.css';

interface Props {
  title: string;
}

const { title } = Astro.props;
const base = import.meta.env.BASE_URL;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Big+Shoulders+Display:wght@700;900&family=JetBrains+Mono:wght@400;500;600&family=Inter:wght@400;500;600&display=swap"
    rel="stylesheet"
  />
</head>
<body>
  <nav class="site-nav">
    <a href={base} class="nav-logo">SOCSIM</a>
    <span class="nav-sep">/</span>
    <span class="nav-sub">Member Portfolio</span>
  </nav>

  <main class="page-main">
    <slot />
  </main>

  <footer class="site-footer">
    <div class="footer-brand"><span>SOCSIM</span> · WDLabs Member Portfolio</div>
    <div class="footer-brand">schema v1.0</div>
  </footer>
</body>
</html>
